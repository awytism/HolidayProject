{
  "name": "gramado-tripboard",
  "version": "2.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node scripts/start-server.mjs",
    "test": "node --test tests/**/*.test.mjs",
    "test:e2e": "node tests/e2e/smoke.mjs",
    "lint": "eslint src tests scripts",
    "check": "npm run lint && npm test",
    "release": "node scripts/build-release.mjs",
    "placeholderize": "node --env-file-if-exists=.env scripts/placeholderize-document.mjs",
    "strip-images": "node --env-file-if-exists=.env scripts/strip-document-images.mjs",
    "auth:hash": "node src/server/hash-password.mjs"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "express": "^5.1.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "eslint": "^9.31.0"
  }
}
