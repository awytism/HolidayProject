upstream gramado_tripboard {
    # Match PORT in data/runtime.env after the first ./start.sh.
    server 127.0.0.1:4177;
    keepalive 16;
}

server {
    listen 80;
    listen [::]:80;
    server_name tripboard.example.com;

    # Slightly above the application's 50 MB per-attachment ceiling.
    client_max_body_size 51m;

    location / {
        proxy_pass http://gramado_tripboard;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }
}
